# =============================================================
# LLM provider — 统一走 OpenAI 兼容协议，切换 provider 即可
# 可选：deepseek | dashscope | volcengine | siliconflow | openai | ollama
# =============================================================
LLM_PROVIDER=deepseek

# --- DeepSeek V4 (https://platform.deepseek.com) ---
# 当前可用 model id：
#   deepseek-v4-flash  ⭐ 推荐 — $0.14/M in、$0.28/M out，1M ctx，对手陪练/prep 性价比最高
#   deepseek-v4-pro    — 推理增强，2026-05-31 前 promo: $0.435/M in、$0.87/M out（之后涨到 $1.74/$3.48），适合评委
#   deepseek-chat / deepseek-reasoner — 旧别名，仍兼容但将废弃
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_JUDGE_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- 阿里云百炼 DashScope (OpenAI 兼容模式) ---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 火山引擎方舟 (Volcengine ARK) ---
VOLCENGINE_API_KEY=
# 注意 model 填的是接入点 endpoint id，例如 ep-2025xxxx-xxxxx
VOLCENGINE_MODEL=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- SiliconFlow ---
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-32B-Instruct
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# --- OpenAI (备用) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama 本地兜底 (M4 Max) ---
# 本机已检测到的可用模型（按性价比排序，更稳的在上）：
#   qwen2.5:14b        9 GB Q4_K_M  ⭐ 推荐 — 中文 + 英文 + 辩论结构都稳
#   gemma4:latest      9.6 GB Q4    — 8B，回答活泼
#   gpt-oss:20b        13.8 GB MXFP4 — 推理强，速度稍慢
#   llama3.2:3b        2 GB         — 极小，仅用于冒烟测试，辩论质量一般
# 切大模型（qwen3.6:27b / gemma4:26b）请确认空闲内存 > 20GB
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# =============================================================
# Judge 专用模型（可选）— 想让 /api/score 走更强推理时设置
# 优先级： JUDGE_MODEL > <PROVIDER>_JUDGE_MODEL > <PROVIDER>_MODEL
# 例如 DeepSeek 想陪练 flash + 评委 pro：上面已默认；想全局覆盖直接：
#   JUDGE_MODEL=deepseek-v4-pro
# =============================================================
JUDGE_MODEL=

# =============================================================
# TTS
# =============================================================
# Provider: edge | openai
#   edge   → 微软 Edge-TTS（默认，免费，Azure Neural）
#   openai → 任何 OpenAI 兼容 /v1/audio/speech 端点，包括：
#            · OpenAI tts-1 / tts-1-hd
#            · VoxCPM via vLLM-Omni (本地 GPU，支持 voice clone + 情绪)
#            · Kokoro-FastAPI / openai-edge-tts 代理
TTS_PROVIDER=edge

# Edge-TTS 默认英文女声，可换 en-US-GuyNeural / zh-CN-XiaoxiaoNeural 等
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# OpenAI-compatible TTS（VoxCPM / Kokoro / OpenAI 本体）
# 例：VoxCPM 本地 vLLM-Omni
#   OPENAI_TTS_BASE_URL=http://localhost:8808/v1
#   OPENAI_TTS_MODEL=voxcpm-2
#   TTS_VOICE=wsc-mascot   # voice clone 注册名或参考音 id
OPENAI_TTS_BASE_URL=
OPENAI_TTS_API_KEY=
OPENAI_TTS_MODEL=tts-1
